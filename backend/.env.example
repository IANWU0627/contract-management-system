# 后端环境变量配置
# 数据库配置
DB_URL=jdbc:mysql://localhost:3306/contract_db?useUnicode=true&characterEncoding=utf8&serverTimezone=Asia/Shanghai&allowPublicKeyRetrieval=true
DB_USERNAME=root
DB_PASSWORD=root

# JWT密钥（必填；请使用高强度随机字符串，勿提交真实值）
JWT_SECRET=replace-with-a-strong-random-jwt-secret

# 外部系统对接 API Key（用于 /api/external/contracts/* 鉴权）
EXTERNAL_API_KEY=replace-with-a-strong-random-key

# CORS允许的源（必填，多个源用逗号分隔；禁止使用 *）
CORS_ORIGINS=http://localhost:3000

# WebSocket允许的源（可选；未设置时沿用 CORS_ORIGINS）
WS_ALLOWED_ORIGINS=http://localhost:3000

# 速率限制
RATE_LIMIT_ENABLED=false
RATE_LIMIT_MAX_REQUESTS=60
